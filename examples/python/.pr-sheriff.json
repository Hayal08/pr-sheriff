{
"max_changed_lines": 800,
"max_changed_files": 30,
"require_tests_after_lines": 120,
"test_patterns": [
"tests/**",
"**/test_*.py",
"**/*_test.py"
],
"sensitive_patterns": [
".github/workflows/**",
"**/auth/**",
"**/security/**",
"**/migrations/**",
"Dockerfile",
"**/Dockerfile",
"poetry.lock",
"pyproject.toml"
],
"ignore_patterns": [
"**/*.md",
"docs/**"
],
"path_rules": []
}
